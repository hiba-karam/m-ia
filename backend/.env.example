# Configuration Serveur
PORT=3000
NODE_ENV=development

# Base de données SQL Server
# Remplacer par vos identifiants locaux
DB_USER=votre_nom_utilisateur
DB_PASSWORD=votre_mot_de_passe
DB_SERVER=localhost\SQLEXPRESS
DB_NAME=M_IA_DB

# Sécurité
# Générer une nouvelle clé aléatoire via la commande crypto
JWT_SECRET=votre_cle_secrete_ici

# API M-support
MSUPPORT_API_URL=
MSUPPORT_API_KEY=

# SSO
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=