# Configuration Serveur
PORT=3000
NODE_ENV=development

# Base de données SQL Server
DB_USER=
DB_PASSWORD=
DB_SERVER=localhost\SQLEXPRESS
DB_NAME=M_IA_DB
DB_ENCRYPT=true
DB_TRUST_CERT=true

# JWT / Sessions
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_DAYS=7

# Auth : local | oidc | saml | ldap
AUTH_MODE=local
LOCAL_LOGIN_ENABLED=true
MFA_REQUIRED_ADMIN=true
DEFAULT_ROLE_NAME=Utilisateur

# OpenID Connect (Microsoft Entra ID recommandé)
OIDC_ISSUER=https://login.microsoftonline.com/{tenant-id}/v2.0
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/api/auth/sso/callback
OIDC_SCOPES=openid profile email groups

# SAML
SAML_ENTRY_POINT=
SAML_ISSUER=m-ia-sp
SAML_CALLBACK_URL=http://localhost:3000/api/auth/saml/callback
SAML_IDP_CERT=
SAML_GROUP_ATTRIBUTE=groups

# LDAP / Active Directory
LDAP_URL=ldap://dc.entreprise.local:389
LDAP_BASE_DN=DC=entreprise,DC=local
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_USER_SEARCH_BASE=OU=Users,DC=entreprise,DC=local
LDAP_USER_SEARCH_FILTER=(sAMAccountName={{username}})
LDAP_GROUP_SEARCH_BASE=OU=Groups,DC=entreprise,DC=local
LDAP_GROUP_MEMBER_ATTRIBUTE=memberOf

# Email Connector : graph | imap (boîte officielle M-support uniquement)
EMAIL_CONNECTOR=graph
MSUPPORT_MAILBOX=msupport@entreprise.ma

# Microsoft Graph API (lecture boîte M-support)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
MSUPPORT_GRAPH_USER_ID=msupport@entreprise.ma

# IMAP sécurisé (alternative)
IMAP_HOST=imap.entreprise.ma
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=msupport@entreprise.ma
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX

# Règles sync email
EMAIL_SYNC_MAX=50
EMAIL_ALLOWED_DOMAINS=
EMAIL_ATTACHMENT_MAX_BYTES=10485760
EMAIL_ALLOWED_EXTENSIONS=.pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg,.txt

# API M-support
MSUPPORT_API_URL=
MSUPPORT_API_KEY=

# SSO (legacy - compatibilité)
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
